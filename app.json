{
  "expo": {
    "name": "CitiSense",
    "slug": "CITISENSE",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mainlogo2.png",
    "scheme": "citisense",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/mainlogo2.png"
      },
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mj.nnyrs.citisense"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/mainlogo2.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "CitiSense needs access to your photos so you can upload complaint evidence.",
          "cameraPermission": "CitiSense needs camera access so you can take complaint evidence photos.",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CitiSense needs your location to tag the complaint location."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/mainlogo2.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/mainlogo2.png",
          "color": "#087A0D",
          "defaultChannel": "default"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "63b257b3-40d4-4718-b751-697f9dd28ebc"
      }
    },
    "ios": {
      "bundleIdentifier": "com.mj.nnyrs.citisense"
    }
  }
}
